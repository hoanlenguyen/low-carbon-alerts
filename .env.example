# Public URL, used for OG Image when running nuxt generate
NUXT_PUBLIC_SITE_URL=

# nuxt-auth-utils session cookie sealing secret (32+ chars)
NUXT_SESSION_PASSWORD=

# Google OAuth (end-user login). Create a separate dev client with redirect
# URI http://localhost:3000/api/auth/google
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=

# One-off token used to gate POST /api/auth/seed-admin (delete env var after seeding)
NUXT_SETUP_TOKEN=
